# Лёгкий «привратник» сайта ООО Зенит.
# Стоит отдельным контейнером перед основным ботом и держит порт 3000 ВСЕГДА,
# поэтому переживает любые редеплои/падения бота и показывает красивую заглушку
# вместо «Bad Gateway».
FROM python:3.10-slim

WORKDIR /app

# Зависимостей нет — guardian написан на чистой стандартной библиотеке.
COPY . .

# Порт, который проксирует Bothost.
ENV PORT=3000
EXPOSE 3000

CMD ["python", "guardian.py"]
